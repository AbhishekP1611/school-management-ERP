<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS / MonsterASP hosting config.
  Sets ASPNETCORE_ENVIRONMENT=Production so the app reads appsettings.Production.json
  (online DB connection + JWT key, kept out of git). No secrets here — safe to commit.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore name="aspNetCore"
                  processPath="dotnet"
                  arguments=".\SchoolErpApi.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
